# Enforce LF line endings for all text tracked by git.
* text=auto eol=lf

# Source and build scripts.
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.s text eol=lf
*.S text eol=lf
*.ld text eol=lf
*.mk text eol=lf
Makefile text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.cmd text eol=lf
*.bat text eol=lf

# Project docs/config.
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary assets and build products (never normalize).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.pvr binary
*.wav binary
*.wav64 binary
*.xm binary
*.xm64 binary
*.mid binary
*.dat binary
*.dfs binary
*.elf binary
*.z64 binary
*.a binary
*.o binary
